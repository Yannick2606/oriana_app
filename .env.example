# ---- Backend orIAna : variables d'environnement ----
# NE JAMAIS committer le vrai .env. Ce fichier ne contient que des noms, pas de secrets.

# Grist (base de données) — la clé vit UNIQUEMENT ici, côté backend
GRIST_API_URL=
GRIST_API_KEY=
GRIST_DOC_ID=

# Session
SESSION_SECRET=
PORT=
FRONTEND_ORIGIN=

# n8n (agents) — webhook + secret partagé
N8N_WEBHOOK_BASE_URL=
N8N_SHARED_SECRET=
BACKEND_PUBLIC_URL=
SUPER_ADMIN_EMAIL=

# Envoi des liens de réinitialisation (Google Workspace ou SMTP compatible)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_APP_PASSWORD=
MAIL_FROM=
FRONTEND_PUBLIC_URL=

# Frontend (valeurs publiques injectées au build)
VITE_API_BASE_URL=
FRONTEND_HOST=
VITE_ORGANIZATION_NAME=
