# ---- Backend orIAna : variables d'environnement ----
# NE JAMAIS committer le vrai .env. Ce fichier ne contient que des noms, pas de secrets.

# Grist (base de données) — la clé vit UNIQUEMENT ici, côté backend
GRIST_API_URL=
GRIST_API_KEY=
GRIST_DOC_ID=

# Session
SESSION_SECRET=
PORT=
FRONTEND_ORIGIN=

# n8n (agents) — webhook + secret partagé
N8N_WEBHOOK_BASE_URL=
N8N_SHARED_SECRET=
