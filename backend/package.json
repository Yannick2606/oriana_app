{
  "name": "@oriana/backend",
  "version": "0.0.0",
  "private": true,
  "description": "Backend proxy orIAna",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "start:sandbox": "node -e \"process.env.ORIANA_SANDBOX_MODE='1'; import('./src/server.js')\"",
    "check:grist": "node scripts/checkGrist.js",
    "audit:grist": "node scripts/auditGrist.js",
    "migrate:postgres": "node scripts/migratePostgres.js",
    "validate:import:grist": "node scripts/validateGristImport.js",
    "import:grist:postgres": "node scripts/importGristPostgres.js",
    "check:patrimoine": "node scripts/checkPatrimoine.js",
    "check:qualification": "node scripts/checkQualification.js",
    "check:offres": "node scripts/checkOffres.js",
    "check:mandats": "node scripts/checkMandats.js",
    "check:crm": "node scripts/checkCrm.js",
    "check:matching": "node scripts/checkMatching.js",
    "check:utilisateurs": "node scripts/checkUtilisateurs.js",
    "prepare:utilisateurs": "node scripts/prepareUtilisateurs.js",
    "prepare:agents": "node scripts/prepareAgents.js",
    "check:agents": "node scripts/checkAgents.js",
    "check:agents:live": "node scripts/checkAgentsLive.js",
    "prepare:patrimoine": "node scripts/preparePatrimoine.js",
    "prepare:qualification": "node scripts/prepareQualification.js",
    "prepare:offres": "node scripts/prepareOffres.js",
    "prepare:mandats": "node scripts/prepareMandats.js",
    "prepare:crm": "node scripts/prepareCrm.js",
    "generate:sandbox": "node scripts/generateSandboxData.js",
    "check:architecture": "node scripts/checkArchitecture.js",
    "lint": "npm run check:architecture && eslint .",
    "test": "node --test"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "express-session": "^1.19.0",
    "nodemailer": "^7.0.13",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "eslint": "^9.31.0",
    "supertest": "^7.1.4"
  }
}
